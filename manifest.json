{
  "name": "Place ID finder",
  "description": "Extracts and copies place IDs from supported Search, Maps, and Travel pages.",
  "version": "1.3.2",
  "manifest_version": 3,
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.google.com/maps/*",
        "https://www.google.com/travel/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "512": "icons/icon-512.png"
  }
}
